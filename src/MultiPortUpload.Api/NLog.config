<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Warn"
      internalLogFile="${logRoot}/logs/nlog-internal.log">

  <!--
    Wurzelverzeichnis für die Logs:
    - Lokal (dotnet run): ${currentdir} ist das Projektverzeichnis
      (src/MultiPortUpload.Api); ../.. zeigt auf das Repo-Wurzelverzeichnis
      -> ./logs im Projekt-Root.
    - Container/anderes Setup: per Umgebungsvariable MPU_LOG_ROOT überschreiben
      (docker-compose setzt MPU_LOG_ROOT=/app -> /app/logs, das gemountete Volume).
  -->
  <variable name="logRoot" value="${environment:MPU_LOG_ROOT:whenEmpty=${currentdir}/../..}" />

  <!--
    Relative Pfade ("logs/..."): lokal (dotnet run) wird nach ./logs geschrieben,
    im Container (WORKDIR /app) nach /app/logs (per docker-compose gemountet).
    Tagesweise Dateinamen über ${shortdate}.
  -->
  <targets>
    <target xsi:type="Console" name="console"
            layout="${longdate} ${uppercase:${level}} ${logger} - ${message} ${exception:format=tostring}" />

    <!-- Default: alle Logs -->
    <target xsi:type="File" name="allfile"
            fileName="${logRoot}/logs/MultiPortUpload-${shortdate}.log"
            layout="${longdate} ${uppercase:${level}} ${logger} - ${message} ${exception:format=tostring}" />

    <!-- API-spezifische Logs (Controller, Endpoints) -->
    <target xsi:type="File" name="apifile"
            fileName="${logRoot}/logs/MultiPortUpload-api-${shortdate}.log"
            layout="${longdate} ${uppercase:${level}} ${logger} [${event-properties:item=EventId_Id}:${event-properties:item=EventId_Name}] - ${message} ${exception:format=tostring}" />

    <!-- Adapter-spezifische Logs (Storage-Adapter) -->
    <target xsi:type="File" name="adapterfile"
            fileName="${logRoot}/logs/MultiPortUpload-adapter-${shortdate}.log"
            layout="${longdate} ${uppercase:${level}} ${logger} [${event-properties:item=EventId_Id}:${event-properties:item=EventId_Name}] - ${message} ${exception:format=tostring}" />

    <!-- Benchmark-/Upload-Service-Logs -->
    <target xsi:type="File" name="benchmarkfile"
            fileName="${logRoot}/logs/MultiPortUpload-benchmark-${shortdate}.log"
            layout="${longdate} ${uppercase:${level}} ${logger} - ${message} ${exception:format=tostring}" />
  </targets>

  <rules>
    <!-- Start-/Stop-Meldungen des Hosts (inkl. "Now listening on ...") behalten -->
    <logger name="Microsoft.Hosting.Lifetime*" minlevel="Info" writeTo="console,allfile" final="true" />

    <!-- Übriges Microsoft-/System-Framework-Rauschen reduzieren -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.*" maxlevel="Info" final="true" />

    <!-- Fachspezifische Ziele (writeTo erlaubt mehrere, kommagetrennt) -->
    <logger name="MultiPortUpload.Api.*" minlevel="Info" writeTo="apifile" />
    <logger name="MultiPortUpload.Infrastructure.Adapters.*" minlevel="Info" writeTo="adapterfile" />
    <logger name="MultiPortUpload.Application.Services.*" minlevel="Info" writeTo="benchmarkfile" />

    <!-- Alles (inkl. der obigen Kategorien) zusätzlich in Konsole + Default-Datei -->
    <logger name="*" minlevel="Info" writeTo="console,allfile" />
  </rules>
</nlog>
