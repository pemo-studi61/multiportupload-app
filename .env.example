# MultiPortUpload – Umgebungsvariablen für docker-compose
#
# Diese Datei dient als Vorlage. Kopiere sie nach .env und trage die echten
# Werte ein. Die .env wird NICHT eingecheckt (siehe .gitignore).
#
#   cp .env.example .env

# Benchmark-Persistenz (PostgreSQL) aktivieren? true/false
# Bei "false" startet die API mit einem No-Op-Store, ohne Datenbank.
BENCHMARK_STORAGE_ENABLED=false

# Npgsql-Verbindungszeichenfolge für die Benchmark-Datenbank.
# Beispiel (Supabase Session Pooler – siehe docs/SUPABASE.md):
#   Host=aws-1-<REGION>.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.<REF>;Password=<DEIN_PASSWORT>;SSL Mode=Require;Trust Server Certificate=true;
BENCHMARK_DB_CONNECTION=

# EF-Core-Migrationen beim Start automatisch anwenden? true/false
BENCHMARK_APPLY_MIGRATIONS=true

# Öffentlich erreichbarer MinIO/S3-Endpoint für presigned Uploads.
# Der EXTERNE Client (Benchmark-Client) lädt direkt hierhin hoch, daher muss die
# presigned URL gegen genau diesen Host signiert werden (SigV4 signiert den Host).
# Lokal genügt der Default (http://localhost:9000); auf dem Server die öffentliche
# Adresse eintragen, z. B.:
#   S3_PUBLIC_ENDPOINT=http://209.38.245.50:9000
# Leer/nicht gesetzt => Fallback auf den internen Endpoint (nur aus dem Docker-Netz erreichbar).
S3_PUBLIC_ENDPOINT=
